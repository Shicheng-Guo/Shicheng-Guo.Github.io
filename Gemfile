source "https://rubygems.org"

# GitHub Pages builds this site with the `github-pages` gem, which pins a
# security-maintained, mutually compatible set of Jekyll + plugin versions.
# Using it locally keeps dev in sync with production and avoids vulnerable
# transitive dependencies.
gem "github-pages", group: :jekyll_plugins

# Plugins used by this site (also bundled by github-pages; listed for clarity).
gem "jekyll-sitemap"
gem "jekyll-paginate"
